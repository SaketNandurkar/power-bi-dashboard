# =============================================================================
# Bizware Power BI Dashboards - Environment Variables
# Copy to .env and fill in production values
# =============================================================================

# Domain
DOMAIN=srv1368855.hstgr.cloud

# PostgreSQL
POSTGRES_DB=bizware_dashboards
POSTGRES_USER=bizware_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# n8n
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_N8N_PASSWORD

# Power BI Embedding
POWERBI_EMBED_URL=

# SSL Email (for Let's Encrypt)
SSL_EMAIL=admin@yourdomain.com

# =============================================================================
# AI Chatbot Configuration
# =============================================================================

# AI Service Enable/Disable
AI_SERVICE_ENABLED=true

# =============================================================================
# LLM Provider Configuration (Choose ONE option below)
# =============================================================================

# OPTION 1: OpenAI (Paid, Best Quality)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-openai-key...
OPENAI_MODEL=gpt-4-turbo-preview
# OPENAI_BASE_URL is not needed for OpenAI

# OPTION 2: Groq (FREE, Fast, Recommended for Demo)
# Get free API key from: https://console.groq.com/
# OPENAI_API_KEY=gsk_...your-groq-key...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.1-70b-versatile

# OPTION 3: OpenRouter (FREE tier available)
# Get free API key from: https://openrouter.ai/
# OPENAI_API_KEY=sk-or-v1-...your-openrouter-key...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=meta-llama/llama-3.1-70b-instruct:free

# OPTION 4: Google Gemini (FREE tier)
# Get free API key from: https://makersuite.google.com/app/apikey
# OPENAI_API_KEY=...your-gemini-key...
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_MODEL=gemini-1.5-flash

# AI Model Parameters
OPENAI_MAX_TOKENS=1500
OPENAI_TEMPERATURE=0.1
AI_REQUEST_TIMEOUT=30000

# SQL Safety Limits
SQL_MAX_ROWS=1000
SQL_TIMEOUT=30000
