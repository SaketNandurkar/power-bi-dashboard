# ============================================================================
# Root .gitignore - Project-level ignores
# Each subdirectory has its own .gitignore for directory-specific patterns
# ============================================================================

# Environment files (root level)
.env
.env.local
.env.*.local

# Logs (root level)
*.log
sync_to_rdp.log

# Test files (root level)
test_*.ps1
test_*.csv
test_*.js

# CSV data files (contain actual business data - do not commit)
*.csv

# Power BI files (large binaries)
*.pbix

# Local exports directory (generated at runtime)
powerbi_exports/

# Docker volumes (persistent data)
pgdata/
n8n_data/

# IDE settings
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
nul

# Claude AI memory (private project memory)
.claude/

# Sample/test data (contains actual data)
sampleXML/

# Temporary documentation
*.md.backup

# Windows sync scripts (contain local paths)
setup_sync_task.ps1
sync_to_rdp.ps1
